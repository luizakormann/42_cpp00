# **************************************************************************** #
#                               configuration                                  #
# **************************************************************************** #

CC		= c++
CFLAGS	= -Wall -Wextra -Werror -std=c++98
RM		= rm -rf


# **************************************************************************** #
#                                   files                                      #
# **************************************************************************** #

NAME	= megaphone
SRC		= megaphone.cpp
OBJ_DIR	= obj/
OBJ 	= $(addprefix $(OBJ_DIR), $(SRC:.cpp=.o))

# **************************************************************************** #
#                              compile commands                                #
# **************************************************************************** #

COMP		= $(CC) $(CFLAGS) $(OBJ) -o $(NAME)
COMP_OBJ	= $(CC) $(CFLAGS) -c $< -o $@

# **************************************************************************** #
#                                  targets                                     #
# **************************************************************************** #

all: $(NAME)
	@echo "compilation completed."

$(OBJ): $(SRC)
	@mkdir -p $(dir $@)
	@$(COMP_OBJ)

$(NAME): $(OBJ)
	@$(COMP)

clean:
	@$(RM) $(OBJ_DIR)

fclean: clean
	@$(RM) $(NAME)

re: fclean all

.PHONY: all clean fclean re
